<!doctype html>
<html lang="en">

<head>
    <!-- Required meta tags -->
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">

    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css"
        integrity="sha384-xOolHFLEh07PJGoPkLv1IbcEPTNtaed2xpHsD9ESMhqIYd0nLMwNLD69Npy4HI+N" crossorigin="anonymous">

    <title>Employee List</title>
    <style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        background: #f4f7fb;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    h1 {
        text-align: center;
        margin: 20px 0;
        font-weight: 600;
        color: #333;
    }

    .container-fluid {
        padding: 20px 30px;
    }

    .btn-info {
        margin-bottom: 15px;
        border-radius: 6px;
        padding: 6px 14px;
    }

    table {
        background: #fff;
        border-radius: 10px;
        overflow: hidden;
        box-shadow: 0 6px 20px rgba(0,0,0,0.08);
    }

    thead {
        background: #007bff;
        color: #fff;
    }

    thead th {
        text-align: center;
        vertical-align: middle !important;
        font-weight: 500;
        font-size: 14px;
    }

    table th,
    table td {
        padding: 10px;
        font-size: 14px;
        vertical-align: middle !important;
    }

    tbody tr {
        transition: 0.2s ease;
    }

    tbody tr:hover {
        background-color: #f1f7ff;
    }

    tbody td {
        color: #444;
    }

    /* Image styling */
    img {
        width: 60px;
        height: 60px;
        object-fit: cover;
        border-radius: 8px;
        border: 1px solid #ddd;
        padding: 2px;
        background: #fff;
    }

    /* Buttons */
    .btn {
        border-radius: 6px;
        padding: 5px 10px;
        font-size: 13px;
    }

    .btn-success:hover {
        background-color: #218838;
    }

    .btn-danger:hover {
        background-color: #c82333;
    }

    /* Status button */
    .btn-success,
    .btn-danger {
        min-width: 90px;
    }

    /* No data message */
    .text-danger {
        font-weight: 500;
    }

    /* Total count */
    span {
        display: block;
        margin-top: 10px;
        font-size: 16px;
        font-weight: 500;
    }

    /* Responsive table */
    @media (max-width: 768px) {
        table {
            font-size: 12px;
        }

        .container-fluid {
            padding: 10px;
        }

        img {
            width: 40px;
            height: 40px;
        }
    }
</style>

</head>

<body>
    <div class="container-fluid">
        <h1>Employee List</h1>
        <a href="/employee/add" class="btn btn-info">Add Employee</a>
        <table class="table table-bordered">
            <thead>
                <tr>
                    <th rowspan="2">#</th>
                    <th rowspan="2">Name</th>
                    <th rowspan="2">Id</th>
                    <th rowspan="2">EmpId</th>
                    <th colspan="5" class="text-center">contact</th>
                    <th rowspan="2">Department</th>
                    <th rowspan="2">Salary</th>
                    <th rowspan="2">Profile Image</th>
                    <th rowspan="2" colspan="3" class="text-center">Actions</th>
                </tr>
                <tr>
                    <th>Phone No.</th>
                    <th>Email</th>
                    <th>Address</th>
                    <th>Full_Address</th>
                    <th>city</th>

                </tr>
            </thead>
            <tbody>
                <%if(data.length===0) {%>
                    <tr>
                        <td colspan="7" class="text-center text-danger">
                            No data found
                        </td>
                    </tr>
                    <% } else { %>
                        <%let index=0%>
                            <% for(let emp of data) {%>

                                <tr>
                                    <td scope="row">
                                        <%= ++index %>
                                    </td>
                                    <td>
                                        <%= emp.name %>
                                    </td>
                                    <td scope="row">
                                        <%let empid=emp._id%>
                                            <%let arr=empid.toString().split("")%>
                                                <% let lastfour=arr.splice(-4).join('')%>
                                                    <%= lastfour %>
                                    </td>

                                    <td>
                                        <%= emp.empid %>
                                    </td>
                                    <td>
                                        <%let len=emp.contact.phno.toString().split("").length%>
                                            <%if(len===10){%>
                                                <%= emp.contact.phno %>
                                                    <%} else {%>
                                                        <span class="fw-bold">Invalid Phone umber</span>
                                                        <% }%>
                                    </td>
                                    <td>
                                        <%= emp.contact.email%>
                                    </td>
                                    <td>
                                        <%= emp.contact.address%>
                                    </td>
                                    <td>
                                        <%= emp.contact.full_address%>
                                    </td>
                                    <td>
                                        <%= emp.contact.city%>
                                    </td>
                                    <td>
                                        <%= emp.department.departname%>
                                    </td>
                                    <td>
                                        <%= emp.salary%>
                                    </td>
                                    <td>
                                        <img src="<%= emp.image.url%>" width="60%">
                                    </td>


                                    <td><a href="/employee/edit/<%= emp._id%>" class="btn btn-success">Update</a></td>
                                    <td><a href="/employee/delete/<%= emp._id%>" class="btn btn-danger">Delete</a></td>

                                    <td>
                                        <a href="/employee/softdelete/<%= emp._id %>"
                                            class="btn <%= emp.isdeleted ? 'btn-danger' : 'btn-success' %>">
                                            <%= emp.isdeleted ? 'Inactive' : 'Active' %>
                                        </a>
                                    </td>
                                </tr>
                                <% }%>
            </tbody>
        </table>
        <span class="fw-bold text-primary">Total =
            <%= data.length %>
        </span>

        <% }%>
    </div>
    <!-- Optional JavaScript; choose one of the two! -->

    <!-- Option 1: jQuery and Bootstrap Bundle (includes Popper) -->
    <script src="https://cdn.jsdelivr.net/npm/jquery@3.5.1/dist/jquery.slim.min.js"
        integrity="sha384-DfXdz2htPH0lsSSs5nCTpuj/zy4C+OGpamoFVy38MVBnE+IbbVYUew+OrCXaRkfj"
        crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-Fy6S3B9q64WdZWQUiU+q4/2Lc9npb8tCaSX9FK7E8HnRr0Jz8D6OP9dO5Vg3Q9ct"
        crossorigin="anonymous"></script>

    <!-- Option 2: Separate Popper and Bootstrap JS -->
    <!--
    <script src="https://cdn.jsdelivr.net/npm/jquery@3.5.1/dist/jquery.slim.min.js" integrity="sha384-DfXdz2htPH0lsSSs5nCTpuj/zy4C+OGpamoFVy38MVBnE+IbbVYUew+OrCXaRkfj" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/popper.js@1.16.1/dist/umd/popper.min.js" integrity="sha384-9/reFTGAW83EW2RDu2S0VKaIzap3H66lZH81PoYlFhbGU+6BZp6G7niu735Sk7lN" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.min.js" integrity="sha384-+sLIOodYLS7CIrQpBjl+C7nPvqq+FbNUBDunl/OZv93DB7Ln/533i8e/mZXLi/P+" crossorigin="anonymous"></script>
    -->
</body>

</html>