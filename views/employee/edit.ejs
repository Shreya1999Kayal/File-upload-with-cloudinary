<!doctype html>
<html lang="en">

<head>
    <!-- Required meta tags -->
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />

    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css"
        integrity="sha384-xOolHFLEh07PJGoPkLv1IbcEPTNtaed2xpHsD9ESMhqIYd0nLMwNLD69Npy4HI+N" crossorigin="anonymous" />

    <title>Update Employee</title>

    <style>
        body {
            background: linear-gradient(135deg, #eef2f7, #dfe9f3);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        .container {
            max-width: 700px;
            margin-top: 40px;
            background: #ffffff;
            padding: 30px 35px;
            border-radius: 12px;
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.1);
        }

        h1 {
            text-align: center;
            font-weight: 600;
            margin-bottom: 25px;
            color: #333;
        }

        h4 {
            margin-top: 25px;
            margin-bottom: 15px;
            font-size: 18px;
            color: #444;
            border-left: 4px solid #007bff;
            padding-left: 10px;
        }

        label {
            font-weight: 500;
            color: #555;
        }

        .form-group {
            margin-bottom: 18px;
        }

        .form-control {
            border-radius: 8px;
            border: 1px solid #ccc;
            padding: 10px;
            transition: 0.3s ease;
        }

        .form-control:focus {
            border-color: #007bff;
            box-shadow: 0 0 6px rgba(0, 123, 255, 0.25);
        }

        .contact,
        .department {
            margin-bottom: 12px;
        }

        input[type="file"] {
            padding: 6px;
            border-radius: 6px;
            background: #f8f9fa;
            border: 1px solid #ccc;
        }

        img {
            border-radius: 10px;
            margin-top: 8px;
            border: 2px solid #ddd;
            padding: 3px;
            background: #fff;
        }

        .btn-primary {
            width: 100%;
            padding: 12px;
            font-size: 16px;
            border-radius: 8px;
            background: #007bff;
            border: none;
            transition: 0.3s ease;
        }

        .btn-primary:hover {
            background: #0056b3;
            transform: translateY(-1px);
        }

        /* Optional: make form slightly responsive */
        @media (max-width: 576px) {
            .container {
                padding: 20px;
            }
        }
    </style>
</head>

<body>
    <div class="container">
        <h1>Update Employee</h1>
        <form action="/employee/update/<%=data._id%>" method="post" enctype="multipart/form-data">
            <div class="form-group">
                <label for="name">Name : </label>
                <input type="text" class="form-control" name="name" value="<%=data.name%>">
            </div>

            <div class="form-group">
                <label for="empid">Empid : </label>
                <input type="number" class="form-control" name="empid" value="<%=data.empid%>">
            </div>

            <div class="form-group">
                <h4>Contact : </h4>

                <div class="contact">
                    <label for="phno">Ph no</label>
                    <input type="text" class="form-control" name="contact[phno]" value="<%=data.contact.phno%>">
                </div>

                <div class="contact">
                    <label for="email">Email</label>
                    <input type="email" class="form-control" name="contact[email]" value="<%=data.contact.email%>">
                </div>

                <div class="contact">
                    <label for="address">address</label>
                    <input type="text" class="form-control" name="contact[address]" value="<%=data.contact.address%>">
                </div>

                <div class="contact">
                    <label for="full_address">Full_address</label>
                    <input type="text" class="form-control" name="contact[full_address]"
                        value="<%=data.contact.full_address%>">
                </div>

                <div class="contact">
                    <label for="city">City</label>
                    <input type="text" class="form-control" name="contact[city]" value="<%=data.contact.city%>">
                </div>
            </div>

            <div class="form-group">
                <h4>Department</h4>
                <div class="department">
                    <label for="departname">Departname</label>
                    <input type="text" class="form-control" name="department[departname]"
                        value="<%=data.department.departname%>">
                </div>
            </div>

            <div class="form-group">
                <label for="Salary">Salary</label>
                <input type="number" class="form-control" name="salary" value="<%=data.salary%>">
            </div>

            <div class="form-group">
                <label>Current Image</label><br>
                <img src="/<%= data.image.url %>" width="120">
            </div>

            <div class="form-group">
                <label>Change Profile Image</label>
                <input type="file" name="image" accept="image/*">
            </div>



            <button type="submit" class="btn btn-primary">Update Employee</button>
        </form>
    </div>

    <!-- Optional JavaScript; choose one of the two! -->

    <!-- Option 1: jQuery and Bootstrap Bundle (includes Popper) -->
    <script src="https://cdn.jsdelivr.net/npm/jquery@3.5.1/dist/jquery.slim.min.js"
        integrity="sha384-DfXdz2htPH0lsSSs5nCTpuj/zy4C+OGpamoFVy38MVBnE+IbbVYUew+OrCXaRkfj"
        crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-Fy6S3B9q64WdZWQUiU+q4/2Lc9npb8tCaSX9FK7E8HnRr0Jz8D6OP9dO5Vg3Q9ct"
        crossorigin="anonymous"></script>

    <!-- Option 2: Separate Popper and Bootstrap JS -->
    <!--
    <script src="https://cdn.jsdelivr.net/npm/jquery@3.5.1/dist/jquery.slim.min.js" integrity="sha384-DfXdz2htPH0lsSSs5nCTpuj/zy4C+OGpamoFVy38MVBnE+IbbVYUew+OrCXaRkfj" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/popper.js@1.16.1/dist/umd/popper.min.js" integrity="sha384-9/reFTGAW83EW2RDu2S0VKaIzap3H66lZH81PoYlFhbGU+6BZp6G7niu735Sk7lN" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.min.js" integrity="sha384-+sLIOodYLS7CIrQpBjl+C7nPvqq+FbNUBDunl/OZv93DB7Ln/533i8e/mZXLi/P+" crossorigin="anonymous"></script>
    -->
</body>

</html>